# App
PORT=4000
JWT_SECRET=your_jwt_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret
ACCESS_TOKEN_TTL=2h
REFRESH_TOKEN_TTL=90d
AUTH_DB_LOOKUP_MODE=token_or_cache
AUTH_USER_CACHE_TTL_MS=300000
TRUST_PROXY=1
JSON_BODY_LIMIT=5mb

# Database
DATABASE_URL=

# CORS
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
ADDITIONAL_ALLOWED_ORIGINS=

# Redis (optional but recommended for scale)
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=cargopilot
REDIS_RATE_LIMIT_PREFIX=cargopilot:ratelimit
RATE_LIMIT_REDIS_STORE_ENABLED=false

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=120
ANALYTICS_RATE_LIMIT_WINDOW_MS=60000
ANALYTICS_RATE_LIMIT_MAX=120
EXPORT_RATE_LIMIT_WINDOW_MS=600000
EXPORT_RATE_LIMIT_MAX=20
LIVE_MAP_SNAPSHOT_RATE_LIMIT_WINDOW_MS=60000
LIVE_MAP_SNAPSHOT_RATE_LIMIT_MAX=240
LIVE_MAP_STREAM_RATE_LIMIT_WINDOW_MS=60000
LIVE_MAP_STREAM_RATE_LIMIT_MAX=60
DRIVER_LOCATION_RATE_LIMIT_WINDOW_MS=60000
DRIVER_LOCATION_RATE_LIMIT_MAX=180
DRIVER_PRESENCE_RATE_LIMIT_WINDOW_MS=60000
DRIVER_PRESENCE_RATE_LIMIT_MAX=240

# Caching / export guard
ANALYTICS_V2_SUMMARY_TTL_MS=300000
ANALYTICS_V2_TREND_TTL_MS=300000
ANALYTICS_V2_WARNINGS_TTL_MS=300000
ANALYTICS_V2_FINANCE_QUEUE_TTL_MS=300000
ANALYTICS_V2_CACHE_JITTER_PCT=0.15
ANALYTICS_V2_CACHE_LOCK_WAIT_MS=800
ANALYTICS_V2_STREAM_HEARTBEAT_MS=25000
ANALYTICS_V2_STREAM_REFRESH_MS=0
ANALYTICS_V2_STREAM_RATE_LIMIT_WINDOW_MS=60000
ANALYTICS_V2_STREAM_RATE_LIMIT_MAX=120
ANALYTICS_SLA_POLICY_DB_ENABLED=false
ANALYTICS_V3_CACHE_JITTER_PCT=0.15
ANALYTICS_V3_DEFAULT_RANGE_DAYS=30
ANALYTICS_V3_DEFAULT_QUEUE_PAGE_SIZE=20
ANALYTICS_WARMUP_ENABLED=true
ANALYTICS_WARMUP_INTERVAL_MS=240000
ANALYTICS_WARMUP_STALE_HOURS=48
ANALYTICS_WORKER_GROUP=cp_analytics_workers
ANALYTICS_WORKER_DEDUPE_TTL_SEC=86400
ANALYTICS_WORKER_FLUSH_DEBOUNCE_MS=1500
ANALYTICS_WORKER_HEALTH_LOG_MS=60000
ANALYTICS_WORKER_IN_PROCESS=false
ANALYTICS_WORKER_LEADER_LOCK_KEY=cargopilot:cp:analytics:worker:lock
ANALYTICS_WORKER_LEADER_LOCK_TTL_SEC=30
ANALYTICS_WORKER_CLEAR_BEFORE_REBUILD=false
ANALYTICS_DIRECT_INVALIDATION=false
OPS_MAX_DURATION_SAMPLES=2000
OPS_SSE_RECONNECT_WINDOW_MS=12000
OPS_SSE_CLIENT_KEEP_MS=360000
OPS_WORKER_LAG_ALERT_MS=30000
OPS_ANALYTICS_P95_ALERT_MS=1500
OPS_CACHE_HIT_ALERT_RATIO=0.7
MANAGER_OVERVIEW_CACHE_TTL_MS=30000
MANAGER_DRIVERS_CACHE_TTL_MS=30000
LIVE_MAP_SNAPSHOT_CACHE_TTL_MS=20000
LIVE_MAP_DRIVER_PROFILE_CACHE_TTL_MS=60000
ORDER_LIST_CACHE_TTL_MS=5000
ORDER_LIST_CACHE_MAX_ENTRIES=500
MAX_EXPORT_ROWS=20000
LIVE_MAP_DRIVER_LOCATION_TTL_SEC=43200
LIVE_MAP_DRIVER_PRESENCE_TTL_SEC=86400
LIVE_MAP_DRIVER_ONLINE_SEC=70
LIVE_MAP_DRIVER_IDLE_SEC=180
LIVE_MAP_DRIVER_STALE_SEC=600
LIVE_MAP_DELTA_MIN_DISTANCE_M=25
LIVE_MAP_DELTA_MAX_INTERVAL_SEC=10
LIVE_MAP_SNAPSHOT_ORDER_LIMIT=300
LIVE_MAP_RECENT_HOURS=72
LIVE_MAP_STREAM_HEARTBEAT_MS=25000
DRIVER_NOTIFICATIONS_RETENTION_DAYS=30
DRIVER_NOTIFICATIONS_CLEANUP_INTERVAL_MS=86400000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DELIVERY_PROOF_MAX_PHOTO_BYTES=6291456

# Payments
PAYMENTS_ENABLED=false
PAYMENT_PROVIDER=stripe
