# App
PORT=4000
JWT_SECRET=your_jwt_secret
TRUST_PROXY=1
JSON_BODY_LIMIT=5mb

# Database
DATABASE_URL=

# CORS
CLIENT_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
ADDITIONAL_ALLOWED_ORIGINS=

# Redis (optional but recommended for scale)
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379
REDIS_PREFIX=cargopilot
REDIS_RATE_LIMIT_PREFIX=cargopilot:ratelimit

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1200
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=120
ANALYTICS_RATE_LIMIT_WINDOW_MS=60000
ANALYTICS_RATE_LIMIT_MAX=120
EXPORT_RATE_LIMIT_WINDOW_MS=600000
EXPORT_RATE_LIMIT_MAX=20

# Caching / export guard
ANALYTICS_CACHE_TTL_MS=30000
MAX_EXPORT_ROWS=20000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Payments
PAYMENTS_ENABLED=false
PAYMENT_PROVIDER=stripe
